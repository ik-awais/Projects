# backend/.env.example
#
# Copy this file to .env and fill in real values. Never commit the actual
# .env file — it is already covered by .gitignore.

# ── Application ───────────────────────────────────────────────────────────
APP_NAME=NovaMind
APP_ENV=development
DEBUG=true

# ── Database ──────────────────────────────────────────────────────────────
# Must use the asyncpg driver scheme. Matches docker/docker-compose.yml's
# default postgres service credentials for local development.
DATABASE_URL=postgresql+asyncpg://novamind:password@localhost:5432/novamind
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security ──────────────────────────────────────────────────────────────
# Generate both with: openssl rand -hex 32
JWT_SECRET=replace_with_openssl_rand_hex_32_output_______________________
ENCRYPTION_KEY=replace_with_a_different_openssl_rand_hex_32_output________

# ── NVIDIA NIM ────────────────────────────────────────────────────────────
# Get both from https://integrate.api.nvidia.com -> API Keys
NVIDIA_API_KEY_1=nvapi-replace-with-your-primary-nvidia-key
NVIDIA_API_KEY_2=nvapi-replace-with-your-secondary-nvidia-key

# ── Search providers ──────────────────────────────────────────────────────
# Tavily: https://app.tavily.com
TAVILY_API_KEY=tvly-replace-with-your-tavily-key
# Brave Search: https://brave.com/search/api
BRAVE_API_KEY=BSA-replace-with-your-brave-search-key

# ── SMTP (email verification / password reset) ────────────────────────────
# Optional for local development — auth/register, /login, /refresh, /logout
# work without these. Required once email verification routes are added.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM_EMAIL=noreply@novamind.local
SMTP_USE_TLS=true

# ── CORS ──────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=["http://localhost:3000"]

# ── Frontend ──────────────────────────────────────────────────────────────
FRONTEND_BASE_URL=http://localhost:3000