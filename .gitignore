# ====================================================================
# MULTI-PROJECT WORKSPACE .GITIGNORE
# ====================================================================

# --------------------------------------------------------------------
# 1. Python Outputs & Caches (NovaMind AI & Solace AI)
# --------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
instance/

# --------------------------------------------------------------------
# 2. C++ Game Build & Caches (nfs_clone / compiler)
# --------------------------------------------------------------------
# Target explicit native compilation outputs and cache logs
CMakeCache.txt
CMakeFiles/
CMakeConfigureLog.yaml
CMakeDirectoryInformation.cmake
CMakeScratch/
Makefile
Makefile2
Makefile.cmake
cmake_install.cmake
progress.marks
TargetDirectories.txt
pkgRedirects/

# Ignore compiled binaries, object files, and dependency trees
*.o
*.o.d
*.bin
/games/nfs_clone/build/
/games/nfs_clone/stubs/
a.out

# --------------------------------------------------------------------
# 3. Frontend Node Dependencies & Build Targets (NovaMind AI)
# --------------------------------------------------------------------
node_modules/
.next/
out/
.pnp
.pnp.js
*.tsbuildinfo
next-env.d.ts

# --------------------------------------------------------------------
# 4. Databases, Backups, and State Logs
# --------------------------------------------------------------------
*.db
*.sqlite3
*.log
*.bak
*.tmp

# --------------------------------------------------------------------
# 5. Environments and Variable Secrets
# --------------------------------------------------------------------
.env
.env.*
*.env
*.venv/
.venv/
venv/

# CRITICAL EXCEPTION: Keep tracked template variables active in layer workflow
!.env.example

# --------------------------------------------------------------------
# 6. Packaging and Distributions
# --------------------------------------------------------------------
dist/
build/
*.egg
*.egg-info/
# --------------------------------------------------------------------
# 7. IDE Profiles and OS Garbage
# --------------------------------------------------------------------
.vscode/
.idea/
.DS_Store
Thumbs.db