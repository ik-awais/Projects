# ====================================================================
# MULTI-PROJECT WORKSPACE .GITIGNORE
# ====================================================================

# --------------------------------------------------------------------
# 1. Python Outputs & Caches (NovaMind AI & Solace AI)
# --------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
instance/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --------------------------------------------------------------------
# 2. C++ Game Build & Caches (nfs_clone / compiler)
# --------------------------------------------------------------------
CMakeCache.txt
CMakeFiles/
CMakeConfigureLog.yaml
CMakeDirectoryInformation.cmake
CMakeScratch/
Makefile
Makefile2
Makefile.cmake
cmake_install.cmake
progress.marks
TargetDirectories.txt
pkgRedirects/

*.o
*.o.d
*.bin
/games/nfs_clone/build/
/games/nfs_clone/stubs/
a.out

# --------------------------------------------------------------------
# 3. Frontend Node Dependencies & Build Targets (NovaMind AI)
# --------------------------------------------------------------------
node_modules/
.next/
out/
.pnp
.pnp.js
*.tsbuildinfo
next-env.d.ts

# --------------------------------------------------------------------
# 4. Databases, Backups, and State Logs
# --------------------------------------------------------------------
*.db
*.sqlite3
*.log
*.bak
*.tmp

# --------------------------------------------------------------------
# 5. Environments and Variable Secrets
# --------------------------------------------------------------------
# Ignore every real env file, in any project, at any depth.
.env
.env.*
*.env
.venv/
venv/

# Exception: template/example env files are safe and SHOULD be tracked,
# since they document required variables without containing real secrets.
# These negations must come after the broad ignores above, and git
# requires the parent directory itself not be ignored for a negation to
# take effect — none of the rules above ignore directories by name, so
# this works at any depth (backend/.env.example, frontend/.env.example,
# solace-ai/.env.example, etc.) without needing a separate line per project.
!.env.example
!**/.env.example
!.env.sample
!**/.env.sample

# --------------------------------------------------------------------
# 6. Packaging and Distributions
# --------------------------------------------------------------------
dist/
build/
*.egg

# --------------------------------------------------------------------
# 7. IDE Profiles and OS Garbage
# --------------------------------------------------------------------
.vscode/
.idea/
.DS_Store
Thumbs.db

# --------------------------------------------------------------------
# 8. NovaMind-specific working files (not part of the deliverable)
# --------------------------------------------------------------------
_quarantine/
*Current Progress*.txt